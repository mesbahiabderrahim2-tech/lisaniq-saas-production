# ══════════════════════════════════════════════════════
# LisanIQ SaaS — Environment Variables
# Copy this to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ══════════════════════════════════════════════════════

# ── Supabase ───────────────────────────────────────────
# Found at: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── App ────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=LisanIQ

# ── Storage ────────────────────────────────────────────
NEXT_PUBLIC_STORAGE_BUCKET=datasets

# ── Stripe ─────────────────────────────────────────────
# Found at: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your-secret-key-here
# Found at: https://dashboard.stripe.com/webhooks (after creating the endpoint)
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret-here
# Server-side price IDs — used to validate checkout requests
STRIPE_PRICE_PRO_MONTHLY=price_your-monthly-price-id
STRIPE_PRICE_PRO_YEARLY=price_your-yearly-price-id
# Public price ID — exposed to the browser so the billing page can
# pre-fill the checkout request. Must match STRIPE_PRICE_PRO_MONTHLY above.
NEXT_PUBLIC_STRIPE_PRICE_PRO_MONTHLY=price_your-monthly-price-id

# ── Feature flags ─────────────────────────────────────
NEXT_PUBLIC_ENABLE_BILLING=false
NEXT_PUBLIC_MAX_FILE_SIZE_MB=25
NEXT_PUBLIC_MAX_DATASETS_FREE=5
